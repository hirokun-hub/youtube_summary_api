# ========================================
# 環境変数設定例
# ========================================
# このファイルをコピーして .env と .env.local を作成してください
#
# 共有可能な設定値: .env に記載
# 機密値（APIキー等）: .env.local に記載
#

# ========================================
# 共有可能な設定値（.env に記載）
# ========================================

# ログレベル（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# Tailscaleホスト名（Tailnetネットワーク内での識別名）
# 例: my-fastapi-server
TAILSCALE_HOSTNAME=fastapi-server


# ========================================
# 機密値（.env.local に記載）
# ========================================

# FastAPI用APIキー（任意の文字列を設定）
# API_KEY=your-secret-api-key-here

# Tailscale認証キー（Tailscaleダッシュボードから取得）
# https://login.tailscale.com/admin/settings/keys
# 推奨: 再利用可能（Reusable）オプションを有効化
# TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxx

# Gemini APIキー（Google AI Studioから取得）
# https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
